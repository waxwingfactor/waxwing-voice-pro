# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8787
DASHBOARD_API_KEY=
SESSION_SECRET=replace-with-32-plus-random-chars
WEBHOOK_SIGNING_SECRET=replace-with-random-webhook-secret
ENCRYPTION_KEY=replace-with-32-byte-base64-key
OWNER_NOTIFICATION_EMAIL=owner@example.com
SENTRY_DSN=

# Gemini Live
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=https://your-api.example.com

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
SUPABASE_STORAGE_BUCKET=call-artifacts

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Morgan Leasing <calls@example.com>"
RESEND_REPLY_TO=leasing@example.com

# Google Calendar OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-api.example.com/google/oauth/callback

# Optional Miro OAuth
MIRO_CLIENT_ID=
MIRO_CLIENT_SECRET=
MIRO_REDIRECT_URI=https://your-api.example.com/miro/oauth/callback
MIRO_DEFAULT_BOARD_ID=
MIRO_ACCESS_TOKEN=
MIRO_REFRESH_TOKEN=
MIRO_WEBHOOK_SECRET=
